<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0f1e"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Section: Angel One Credentials -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="ANGEL ONE CREDENTIALS"
            android:textColor="#64748b"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:hint="API Key"
            app:boxBackgroundColor="#111827"
            app:boxStrokeColor="#1e293b"
            app:hintTextColor="#64748b"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="textVisiblePassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:hint="Client ID"
            app:boxBackgroundColor="#111827"
            app:boxStrokeColor="#1e293b"
            app:hintTextColor="#64748b"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputClientId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="textVisiblePassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:hint="Password"
            app:boxBackgroundColor="#111827"
            app:boxStrokeColor="#1e293b"
            app:hintTextColor="#64748b"
            app:endIconMode="password_toggle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="TOTP Secret"
            app:boxBackgroundColor="#111827"
            app:boxStrokeColor="#1e293b"
            app:hintTextColor="#64748b"
            app:helperText="The base32 secret from your authenticator app setup"
            app:helperTextTextColor="#475569"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputTotp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="textVisiblePassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestLogin"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="24dp"
            android:text="Test Connection"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:backgroundTint="#1e3a5f"
            app:cornerRadius="8dp" />

        <!-- Section: Scan Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="SCAN SETTINGS"
            android:textColor="#64748b"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Portfolio scan interval"
                android:textColor="#94a3b8"
                android:textSize="13sp" />
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputScanInterval"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:background="@drawable/input_bg"
                android:gravity="center"
                android:text="15"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="number"
                android:padding="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="min"
                android:textColor="#64748b"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Sell alert threshold"
                android:textColor="#94a3b8"
                android:textSize="13sp" />
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputSellThreshold"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:background="@drawable/input_bg"
                android:gravity="center"
                android:text="45"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="number"
                android:padding="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="pts"
                android:textColor="#64748b"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Strong sell threshold"
                android:textColor="#94a3b8"
                android:textSize="13sp" />
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputStrongSellThreshold"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:background="@drawable/input_bg"
                android:gravity="center"
                android:text="65"
                android:textColor="#f1f5f9"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:inputType="number"
                android:padding="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="pts"
                android:textColor="#64748b"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Toggles -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:padding="8dp"
            android:text="Push notifications"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:checked="true"
            app:thumbTint="#059669"
            app:trackTint="#1e293b" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchMarketHours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:padding="8dp"
            android:text="Scan during market hours only"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:checked="true"
            app:thumbTint="#059669"
            app:trackTint="#1e293b" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:padding="8dp"
            android:text="Vibrate on alerts"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:checked="true"
            app:thumbTint="#059669"
            app:trackTint="#1e293b" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#059669"
            app:cornerRadius="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp" />
    </LinearLayout>
</ScrollView>
