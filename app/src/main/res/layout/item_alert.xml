<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#1a1020"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Alert type indicator -->
        <View
            android:id="@+id/alertStrip"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="#dc2626" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/alertSymbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYMBOL"
                    android:textColor="#f1f5f9"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/alertBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="SELL"
                    android:textColor="#dc2626"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_sell_bg" />
            </LinearLayout>

            <TextView
                android:id="@+id/alertMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Alert message"
                android:textColor="#94a3b8"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Score + Price -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/alertSellScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65"
                android:textColor="#dc2626"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/alertPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textColor="#64748b"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
